# Required
GITHUB_TOKEN=ghp_your_github_token
WEBHOOK_SECRET=replace_with_webhook_secret
LLM_API_KEY=replace_with_provider_api_key

# Optional model routing
PH_LLM_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
PH_LLM_MODEL=meta/llama-3.1-8b-instruct

# Optional runtime tuning
PH_WEBHOOK_WORKERS=4
PH_INLINE_COMMENTS=true
PH_SECURITY_SCAN=true
PH_MAX_DIFF_BYTES=200000
